# ──────────────────────────────────────────
# Lead Qualifier — Environment Variables
# Copy this to .env and fill in your values
# ──────────────────────────────────────────

### FastAPI
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

### Database (SQLite — local file-based, no setup needed)
DATABASE_URL=sqlite+aiosqlite:///./data/leads.db

### AI — Gemini 2.5 Flash
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=30
GEMINI_MAX_RETRIES=2

### Google Sheets
GOOGLE_SHEETS_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
GOOGLE_SHEETS_SPREADSHEET_ID=your-google-sheet-id-here
GOOGLE_SHEETS_SHEET_NAME=Leads

### Brevo (transactional email)
BREVO_API_KEY=your-brevo-api-key-here
BREVO_FROM_EMAIL=leads@yourcompany.com
BREVO_FROM_NAME=Lead Qualifier
NOTIFICATION_TO_EMAIL=team@yourcompany.com

### Slack (optional — leave blank to skip)
SLACK_WEBHOOK_URL=
SLACK_HOT_CHANNEL=urgent-leads
SLACK_DEFAULT_CHANNEL=general

### Webhook Security (optional — if you want to require a secret token)
WEBHOOK_SECRET=